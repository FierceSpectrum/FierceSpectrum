    "aboutMe": {
        "title": "About Me",
        "introduction": "I am a <strong>Full Stack</strong> developer with a special focus on <strong>backend</strong>. I am currently studying <strong>Software Engineering</strong> and am passionate about creating web solutions that solve complex problems. I specialize in designing and developing <strong>APIs</strong>, managing database, and tackling technical challenges with creativity and precision.",
        "passion": "I am always on the lookout for new technologies and methods to improve my skills. If you wish to connect or learn more about my work, feel free to contact me through social media.",
        "email": "benjaminsandisalas@gmail.com",
        "highlights": [
            {
                "title": "Backend",
                "description": "Node.js, Express, PostgreSQL, MongoDB",
                "icon": "FiServer"
            },
            {
                "title": "Frontend",
                "description": "React, JavaScript, SCSS, HTML5",
                "icon": "FiLayout"
            },
            {
                "title": "More About Me",
                "description": "My journey and interests",
                "icon": "FiUser",
                "isButton": true
            }
        ],
        "modal": {
            "AboutMe": {
                "title": "My Journey in Software Engineering",
                "description": "I am a passionate Software Engineering student. My path to programming wasn't direct; initially, I was more inclined towards mathematics. However, I discovered that my true passion lay in solving complex problems and creating innovative solutions. Programming offers me the continuous challenge of learning and adapting, which motivates me to keep growing in this field. I decided to specialize in Full Stack, covering both Backend and Frontend, because I love having a complete view of how an application works, from the database to the user interface."
            },
            "Leadership": {
                "title": "Interpersonal Skills",
                "description": "I am a curious and insatiable person, always looking to learn and improve. I consider myself a collaborative leader who values empathy and cooperation. I enjoy solving problems and helping others overcome their challenges. I believe in the importance of not leaving anyone behind and fostering an environment of continuous learning."
            },
            "Personal_Interests": {
                "title": "Personal Interests",
                "description": "Outside of programming, I enjoy activities like chess, which fuels my love for logic and strategy. I like listening to music, especially electronic music, and I enjoy swimming, which helps me maintain a healthy balance. Additionally, I highly value time with my family and friends, and I enjoy outdoor activities like going to the beach and playing board games."
            }
        }
    },
